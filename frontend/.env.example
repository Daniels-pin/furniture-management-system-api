# Frontend (Vite)
# Vite only exposes env vars prefixed with VITE_.
#
# API base URL (required for production / `vite preview`; dev falls back to http://localhost:8000 if unset).
VITE_API_URL=http://localhost:8000
#
# Production (e.g. Vercel): set VITE_API_URL to your deployed API origin, e.g.:
# VITE_API_URL=https://your-api.example.com
#
# Optional: absolute logo URL for PDF/email parity with the API
# VITE_LOGO_URL=https://...
